generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String    @id @default(uuid()) @db.VarChar(36)
  nombre         String    @db.VarChar(120)
  slug           String    @unique @db.VarChar(60)
  contactoNombre String?   @db.VarChar(120)
  contactoCorreo String?   @db.VarChar(150)
  telefono       String?   @db.VarChar(20)
  logoBase64     String?   @db.LongText
  mision         String?   @db.LongText
  vision         String?   @db.LongText
  serviciosInfo  String?   @db.LongText
  horariosInfo   String?   @db.LongText
  redesSociales  String?   @db.LongText
  activo         Boolean   @default(true) @db.Bit(1)
  plan           String    @default("starter") @db.VarChar(30)
  maxUsuarios    Int       @default(20)
  paqueteId      String?   @db.VarChar(36)
  periodoPlan     String    @default("mensual") @db.VarChar(20)
  proximoPago     DateTime? @db.DateTime(3)
  paisCodigo      String    @default("HN") @db.VarChar(5)
  monedaCodigo    String    @default("HNL") @db.VarChar(10)
  teamSize        String?   @db.VarChar(20)
  authProvider    String    @default("password") @db.VarChar(20)
  trialEndsAt      DateTime? @db.DateTime(3)
  fechaExpiracion  DateTime? @db.DateTime(3)
  estado           String    @default("vigente") @db.VarChar(20)
  paypalCustomerId String?   @db.VarChar(120)
  createAt        DateTime  @default(now())
  updateAt        DateTime  @updatedAt

  roles                  Rol[]
  empleados              Empleados[]
  puestos                Puesto[]
  usuarios               Usuarios[]
  seguros                Seguro[]
  pacientes              Paciente[]
  profesiones            Profesion[]
  servicios              Servicio[]
  promociones            Promocion[]
  promocionServicios     PromocionServicio[]
  medicos                Medico[]
  consultorios           Consultorio[]
  citas                  Cita[]
  consultas              Consulta[]
  consultaServicios      ConsultaServicio[]
  productos              Producto[]
  consultaProductos      ConsultaProducto[]
  cotizaciones           Cotizacion[]
  cotizacionServicios    CotizacionServicio[]
  planTratamientos       PlanTratamiento[]
  planEtapas             PlanEtapa[]
  planEtapaServicios     PlanEtapaServicio[]
  seguimientos           Seguimiento[]
  pagos                  Pago[]
  financiamientos        Financiamiento[]
  ordenesCobro           OrdenDeCobro[]
  cuotasFinanciamiento   CuotaFinanciamiento[]
  constanciasMedicas     ConstanciaMedica[]
  recibos                Recibo[]
  reciboDetalles         ReciboDetalle[]
  solicitudesCitaPublica SolicitudCitaPublica[]
  whatsappConfig         TenantWhatsappConfig?
  whatsappMensajes       TenantWhatsappMensaje[]
  tenantInvoices         TenantInvoice[]
  paquete                Paquete?               @relation(fields: [paqueteId], references: [id])

  @@index([paqueteId])
}

model Paquete {
  id               String   @id @default(uuid()) @db.VarChar(36)
  nombre           String   @unique @db.VarChar(80)
  descripcion      String?  @db.VarChar(255)
  precio           Decimal  @default(0) @db.Decimal(10, 2)
  precioTrimestral Decimal? @db.Decimal(10, 2)
  precioSemestral  Decimal? @db.Decimal(10, 2)
  precioAnual      Decimal? @db.Decimal(10, 2)
  maxUsuarios      Int      @default(20)
  trialActivo      Boolean  @default(false) @db.Bit(1)
  trialDias        Int      @default(0)
  activo           Boolean  @default(true) @db.Bit(1)
  createAt         DateTime @default(now())
  updateAt         DateTime @updatedAt

  tenants        Tenant[]
  tenantInvoices TenantInvoice[]
}

model TenantInvoice {
  id               String   @id @default(uuid()) @db.VarChar(36)
  tenantId         String   @db.VarChar(36)
  paqueteId        String   @db.VarChar(36)
  periodoPlan      String   @db.VarChar(20)
  monto            Decimal  @db.Decimal(10, 2)
  subtotal         Decimal? @db.Decimal(10, 2)
  impuesto         Decimal? @db.Decimal(10, 2)
  total            Decimal? @db.Decimal(10, 2)
  moneda           String   @default("USD") @db.VarChar(10)
  estado           String   @default("pendiente") @db.VarChar(20)
  numeroFactura    String?  @db.VarChar(40)
  facturarNombre   String?  @db.VarChar(150)
  facturarCorreo   String?  @db.VarChar(150)
  facturarTelefono String?  @db.VarChar(30)
  facturarTaxId    String?  @db.VarChar(40)
  facturarDireccion String? @db.VarChar(255)
  facturarCiudad   String?  @db.VarChar(80)
  facturarPais     String?  @db.VarChar(80)
  facturarPostal   String?  @db.VarChar(20)
  descripcion      String?  @db.VarChar(255)
  paypalOrderId    String?  @db.VarChar(120)
  paypalCaptureId  String?  @db.VarChar(120)
  fechaFacturacion DateTime @default(now())
  fechaPago        DateTime?
  createAt         DateTime @default(now())
  updateAt         DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paquete Paquete @relation(fields: [paqueteId], references: [id])

  @@index([tenantId, estado])
  @@index([paypalOrderId])
}

model Permiso {
  id          String       @id @default(uuid())
  nombre      String       @db.VarChar(100)
  descripcion String
  createAt    DateTime     @default(now())
  updateAt    DateTime     @updatedAt
  activo      Boolean
  roles       RolPermiso[]

  @@unique([nombre])
}

model RolPermiso {
  id        String   @id @default(uuid())
  rolId     String
  permisoId String
  createAt  DateTime @default(now())

  permiso Permiso @relation(fields: [permisoId], references: [id])
  rol     Rol     @relation(fields: [rolId], references: [id])

  @@unique([rolId, permisoId])
  @@index([permisoId], map: "RolPermiso_permisoId_fkey")
}

model Rol {
  id          String       @id @default(uuid())
  tenantId    String?      @db.VarChar(36)
  nombre      String       @db.VarChar(80)
  descripcion String
  createAt    DateTime     @default(now())
  updateAt    DateTime     @updatedAt
  activo      Boolean
  permisos    RolPermiso[]
  usuarios    Usuarios[]
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model Empleados {
  id        String  @id @default(uuid()) @db.VarChar(36)
  tenantId  String? @db.VarChar(36)
  puesto_id String  @db.VarChar(36)

  identidad       String    @db.VarChar(50)
  nombre          String    @db.VarChar(100)
  apellido        String    @db.VarChar(100)
  correo          String    @db.LongText
  FechaNacimiento DateTime? @db.DateTime(6)
  fechaIngreso    DateTime? @db.DateTime(6)
  telefono        String?   @db.VarChar(20)

  Vacaciones Int
  genero     String?  @db.VarChar(20)
  activo     Boolean  @db.Bit(1)
  createAt   DateTime @default(now())
  updateAt   DateTime @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Puesto   Puesto    @relation(fields: [puesto_id], references: [Id], onDelete: Cascade, onUpdate: NoAction)
  Usuarios Usuarios?
  Medico   Medico?

  @@unique([tenantId, identidad])
  @@index([tenantId])
  @@index([puesto_id])
}

model Puesto {
  Id          String      @id @db.VarChar(36)
  tenantId    String?     @db.VarChar(36)
  Nombre      String      @db.VarChar(100)
  Descripcion String      @db.VarChar(100)
  Activo      Boolean     @db.Bit(1)
  createAt    DateTime    @default(now())
  updateAt    DateTime    @updatedAt
  Empleados   Empleados[]
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, Nombre])
  @@index([tenantId])
}

model Usuarios {
  id                  String               @id @db.VarChar(36)
  tenantId            String?              @db.VarChar(36)
  empleado_id         String?              @unique(map: "IX_Usuarios_empleado_id") @db.VarChar(36)
  usuario             String               @db.VarChar(50)
  correo              String?              @db.VarChar(150)
  contrasena          String               @db.LongText
  DebeCambiarPassword Boolean?
  createAt            DateTime             @default(now())
  updateAt            DateTime             @updatedAt
  rol_id              String               @db.VarChar(36)
  activo              Boolean              @db.Bit(1)
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Empleados           Empleados?           @relation(fields: [empleado_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Usuarios_Empleados_empleado_id")
  rol                 Rol                  @relation(fields: [rol_id], references: [id])
  PasswordResetToken  PasswordResetToken[]
  recibosEmitidos     Recibo[]             @relation("ReciboEmitidoPor")

  @@unique([tenantId, usuario])
  @@index([tenantId])
  @@index([rol_id], map: "IX_Usuarios_rol_id")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  token     String   @unique @db.VarChar(128)
  expiresAt DateTime
  createdAt DateTime @default(now())

  Usuario Usuarios @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "IX_PasswordResetToken_userId")
}

model RegistrationEmailToken {
  id         String    @id @default(uuid()) @db.VarChar(36)
  email      String    @db.VarChar(150)
  token      String    @unique @db.VarChar(128)
  expiresAt  DateTime
  verifiedAt DateTime?
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email], map: "IX_RegistrationEmailToken_email")
}

model Seguro {
  id          String   @id @default(uuid()) @db.VarChar(36)
  tenantId    String?  @db.VarChar(36)
  nombre      String   @db.VarChar(100)
  descripcion String?  @db.VarChar(255)
  activo      Boolean  @db.Bit(1)
  createAt    DateTime @default(now())
  updateAt    DateTime @updatedAt

  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pacientes Paciente[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model Paciente {
  id              String          @id @default(uuid()) @db.VarChar(36)
  tenantId        String?         @db.VarChar(36)
  identidad       String          @db.VarChar(50)
  nombre          String          @db.VarChar(100)
  apellido        String          @db.VarChar(100)
  fechaNacimiento DateTime?       @db.DateTime(6)
  genero          String?         @db.VarChar(20)
  telefono        String?         @db.VarChar(20)
  correo          String?         @db.VarChar(150)
  direccion       String?         @db.VarChar(255)
  conocioClinica  ConocioClinica?

  seguroId String? @db.VarChar(36)
  seguro   Seguro? @relation(fields: [seguroId], references: [id])

  activo   Boolean  @db.Bit(1)
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citas              Cita[]
  cotizaciones       Cotizacion[]
  planTratamientos   PlanTratamiento[]
  seguimientos       Seguimiento[]
  financiamientos    Financiamiento[]
  ordenesCobro       OrdenDeCobro[]
  constanciasMedicas ConstanciaMedica[]

  @@unique([tenantId, identidad])
  @@index([tenantId])
  @@index([seguroId])
}

enum ConocioClinica {
  REDES_SOCIALES
  AMIGOS
  MEDIO_COMUNICACION
  OTROS
}

model Profesion {
  id          String   @id @default(uuid()) @db.VarChar(36)
  tenantId    String?  @db.VarChar(36)
  nombre      String   @db.VarChar(100)
  descripcion String?  @db.VarChar(255)
  activo      Boolean  @db.Bit(1)
  createAt    DateTime @default(now())
  updateAt    DateTime @updatedAt

  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicos Medico[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model Servicio {
  id               String   @id @default(uuid()) @db.VarChar(36)
  tenantId         String?  @db.VarChar(36)
  nombre           String   @db.VarChar(150)
  descripcion      String?  @db.VarChar(255)
  precioBase       Decimal  @db.Decimal(10, 2)
  duracionMin      Int
  activo           Boolean  @db.Bit(1)
  mostrarEnLanding Boolean  @default(false) @db.Bit(1)
  createAt         DateTime @default(now())
  updateAt         DateTime @updatedAt

  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medicosServicios    MedicoServicio[]
  consultasServicios  ConsultaServicio[]
  cotizacionServicios CotizacionServicio[]
  planEtapaServicios  PlanEtapaServicio[]
  promocionesServicio PromocionServicio[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("Servicios")
}

model Medico {
  id       String  @id @default(uuid()) @db.VarChar(36)
  tenantId String? @db.VarChar(36)

  idEmpleado String    @unique @db.VarChar(36)
  empleado   Empleados @relation(fields: [idEmpleado], references: [id], onDelete: Cascade)

  profesionId String    @db.VarChar(36)
  profesion   Profesion @relation(fields: [profesionId], references: [id])

  activo   Boolean  @db.Bit(1)
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviciosMedicos   MedicoServicio[]
  citas              Cita[]
  planTratamientos   PlanTratamiento[]
  planEtapas         PlanEtapa[]
  constanciasMedicas ConstanciaMedica[]

  @@index([tenantId])
  @@map("Medicos")
}

model MedicoServicio {
  id         String   @id @default(uuid())
  medicoId   String   @db.VarChar(36)
  servicioId String   @db.VarChar(36)
  createAt   DateTime @default(now())

  medico   Medico   @relation(fields: [medicoId], references: [idEmpleado])
  servicio Servicio @relation(fields: [servicioId], references: [id])

  @@unique([medicoId, servicioId])
  @@index([servicioId])
  @@map("Medicos_Servicios")
}

model Consultorio {
  id        String   @id @default(uuid()) @db.VarChar(36)
  tenantId  String?  @db.VarChar(36)
  nombre    String   @db.VarChar(50)
  ubicacion String?  @db.VarChar(150)
  activo    Boolean  @db.Bit(1)
  createAt  DateTime @default(now())
  updateAt  DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citas  Cita[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model Cita {
  id            String  @id @default(uuid()) @db.VarChar(36)
  tenantId      String? @db.VarChar(36)
  pacienteId    String  @db.VarChar(36)
  medicoId      String  @db.VarChar(36)
  consultorioId String  @db.VarChar(36)

  fechaHora DateTime @db.DateTime(6)
  estado    String   @db.VarChar(20)

  motivo      String? @db.VarChar(255)
  observacion String? @db.VarChar(255)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente    Paciente    @relation(fields: [pacienteId], references: [id])
  medico      Medico      @relation(fields: [medicoId], references: [idEmpleado])
  consultorio Consultorio @relation(fields: [consultorioId], references: [id])

  consulta     Consulta?
  seguimientos Seguimiento[]

  @@index([tenantId])
  @@index([pacienteId])
  @@index([medicoId])
  @@index([consultorioId])
}

model Consulta {
  id       String  @id @default(uuid()) @db.VarChar(36)
  tenantId String? @db.VarChar(36)
  citaId   String  @unique @db.VarChar(36)

  fechaConsulta         DateTime? @db.DateTime(6)
  diagnostico           String?   @db.VarChar(255)
  notas                 String?   @db.Text
  observacionesClinicas String?   @db.Text
  piezasTratadas        String?   @db.Text
  total                 Decimal   @default(0) @db.Decimal(10, 2)
  descuento             Decimal?  @db.Decimal(10, 2)
  seguimientoId         String?   @db.VarChar(36)
  financiamientoId      String?   @db.VarChar(36)
  promocionId           String?   @db.VarChar(36)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cita           Cita            @relation(fields: [citaId], references: [id], onDelete: Cascade)
  seguimiento    Seguimiento?    @relation(fields: [seguimientoId], references: [id])
  financiamiento Financiamiento? @relation(fields: [financiamientoId], references: [id])
  promocion      Promocion?      @relation(fields: [promocionId], references: [id])

  detalles     ConsultaServicio[]
  productos    ConsultaProducto[]
  planEtapas   PlanEtapa[]
  ordenesCobro OrdenDeCobro[]

  @@index([tenantId])
  @@index([seguimientoId])
  @@index([financiamientoId])
  @@index([promocionId])
}

model Promocion {
  id                String    @id @default(uuid()) @db.VarChar(36)
  tenantId          String?   @db.VarChar(36)
  nombre            String    @db.VarChar(150)
  descripcion       String?   @db.VarChar(255)
  precioReferencial Decimal   @default(0) @db.Decimal(10, 2)
  precioPromocional Decimal   @default(0) @db.Decimal(10, 2)
  fechaInicio       DateTime?
  fechaFin          DateTime?
  activo            Boolean   @db.Bit(1)
  mostrarEnLanding  Boolean   @default(false) @db.Bit(1)
  createAt          DateTime  @default(now())
  updateAt          DateTime  @updatedAt

  tenant    Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  servicios PromocionServicio[]
  consultas Consulta[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model PromocionServicio {
  id             String   @id @default(uuid()) @db.VarChar(36)
  tenantId       String?  @db.VarChar(36)
  promocionId    String   @db.VarChar(36)
  servicioId     String   @db.VarChar(36)
  precioAplicado Decimal? @db.Decimal(10, 2)
  cantidad       Int      @default(1)
  createAt       DateTime @default(now())

  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  promocion Promocion @relation(fields: [promocionId], references: [id], onDelete: Cascade)
  servicio  Servicio  @relation(fields: [servicioId], references: [id])

  @@unique([promocionId, servicioId])
  @@index([tenantId])
  @@index([servicioId])
}

model ConsultaServicio {
  id         String  @id @default(uuid()) @db.VarChar(36)
  tenantId   String? @db.VarChar(36)
  consultaId String  @db.VarChar(36)
  servicioId String  @db.VarChar(36)

  precioAplicado Decimal @db.Decimal(10, 2)
  cantidad       Int     @default(1)

  createAt DateTime @default(now())

  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consulta Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  servicio Servicio @relation(fields: [servicioId], references: [id])

  @@index([tenantId])
  @@index([consultaId])
  @@index([servicioId])
}

model Producto {
  id          String   @id @default(uuid()) @db.VarChar(36)
  tenantId    String?  @db.VarChar(36)
  nombre      String   @db.VarChar(150)
  descripcion String?  @db.VarChar(255)
  tipo        TipoProducto @default(CONSUMIBLE)
  precioVenta Decimal? @db.Decimal(10, 2)
  unidad      String?  @db.VarChar(50)
  stock       Int      @default(0)
  stockMinimo Int      @default(0)
  activo      Boolean  @db.Bit(1)
  createAt    DateTime @default(now())
  updateAt    DateTime @updatedAt

  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consultasProductos ConsultaProducto[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@index([nombre])
}

model ConsultaProducto {
  id         String   @id @default(uuid()) @db.VarChar(36)
  tenantId   String?  @db.VarChar(36)
  consultaId String   @db.VarChar(36)
  productoId String   @db.VarChar(36)
  cantidad   Int      @default(1)
  precioUnitarioAplicado Decimal @default(0) @db.Decimal(10, 2)
  createAt   DateTime @default(now())

  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consulta Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([tenantId])
  @@index([consultaId])
  @@index([productoId])
}

enum TipoProducto {
  CONSUMIBLE
  VENTA
}

model Cotizacion {
  id         String  @id @default(uuid()) @db.VarChar(36)
  tenantId   String? @db.VarChar(36)
  pacienteId String  @db.VarChar(36)

  fecha       DateTime @default(now())
  estado      String   @db.VarChar(20)
  total       Decimal  @db.Decimal(10, 2)
  observacion String?  @db.VarChar(255)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant          Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente        Paciente             @relation(fields: [pacienteId], references: [id])
  detalles        CotizacionServicio[]
  financiamientos Financiamiento[]

  @@index([tenantId])
  @@index([pacienteId])
}

model CotizacionServicio {
  id           String  @id @default(uuid()) @db.VarChar(36)
  tenantId     String? @db.VarChar(36)
  cotizacionId String  @db.VarChar(36)
  servicioId   String  @db.VarChar(36)

  precioUnitario Decimal @db.Decimal(10, 2)
  cantidad       Int     @default(1)

  observacion String? @db.VarChar(255)

  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  servicio   Servicio   @relation(fields: [servicioId], references: [id])

  @@unique([cotizacionId, servicioId])
  @@index([tenantId])
  @@index([servicioId])
}

enum PlanEstado {
  ACTIVO
  PAUSADO
  COMPLETADO
  CANCELADO
}

enum SeguimientoEstado {
  PENDIENTE
  REALIZADO
}

model PlanTratamiento {
  id                  String     @id @default(uuid()) @db.VarChar(36)
  tenantId            String?    @db.VarChar(36)
  pacienteId          String     @db.VarChar(36)
  nombre              String     @db.VarChar(150)
  descripcion         String?    @db.VarChar(255)
  estado              PlanEstado @default(ACTIVO)
  fechaInicio         DateTime   @db.DateTime(6)
  fechaFin            DateTime?  @db.DateTime(6)
  medicoResponsableId String?    @db.VarChar(36)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente          Paciente         @relation(fields: [pacienteId], references: [id])
  medicoResponsable Medico?          @relation(fields: [medicoResponsableId], references: [idEmpleado])
  etapas            PlanEtapa[]
  financiamientos   Financiamiento[]
  ordenesCobro      OrdenDeCobro[]

  @@index([tenantId])
  @@index([pacienteId])
  @@index([medicoResponsableId])
}

model PlanEtapa {
  id          String  @id @default(uuid()) @db.VarChar(36)
  tenantId    String? @db.VarChar(36)
  planId      String  @db.VarChar(36)
  nombre      String  @db.VarChar(150)
  descripcion String? @db.VarChar(255)
  orden       Int     @default(1)

  intervaloDias        Int?
  repeticiones         Int?
  programarCita        Boolean @default(true) @db.Bit(1)
  responsableMedicoId  String? @db.VarChar(36)
  crearDesdeConsultaId String? @db.VarChar(36)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant             Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan               PlanTratamiento     @relation(fields: [planId], references: [id], onDelete: Cascade)
  responsableMedico  Medico?             @relation(fields: [responsableMedicoId], references: [idEmpleado])
  crearDesdeConsulta Consulta?           @relation(fields: [crearDesdeConsultaId], references: [id])
  seguimientos       Seguimiento[]
  servicios          PlanEtapaServicio[]

  @@unique([planId, orden])
  @@index([tenantId])
  @@index([planId])
  @@index([responsableMedicoId])
  @@index([crearDesdeConsultaId])
}

model PlanEtapaServicio {
  id             String   @id @default(uuid()) @db.VarChar(36)
  tenantId       String?  @db.VarChar(36)
  etapaId        String   @db.VarChar(36)
  servicioId     String   @db.VarChar(36)
  cantidad       Int      @default(1)
  precioAplicado Decimal? @db.Decimal(10, 2)
  createAt       DateTime @default(now())

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  etapa    PlanEtapa @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  servicio Servicio  @relation(fields: [servicioId], references: [id])

  @@unique([etapaId, servicioId])
  @@index([tenantId])
  @@index([etapaId])
  @@index([servicioId])
}

model Seguimiento {
  id              String            @id @default(uuid()) @db.VarChar(36)
  tenantId        String?           @db.VarChar(36)
  etapaId         String            @db.VarChar(36)
  pacienteId      String            @db.VarChar(36)
  fechaProgramada DateTime          @db.DateTime(6)
  fechaRealizada  DateTime?         @db.DateTime(6)
  estado          SeguimientoEstado @default(PENDIENTE)
  nota            String?           @db.VarChar(255)
  citaId          String?           @db.VarChar(36)
  creadoPorId     String?           @db.VarChar(36)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant       Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  etapa        PlanEtapa      @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  paciente     Paciente       @relation(fields: [pacienteId], references: [id])
  cita         Cita?          @relation(fields: [citaId], references: [id])
  ordenesCobro OrdenDeCobro[]
  consultas    Consulta[]

  @@index([tenantId])
  @@index([etapaId])
  @@index([pacienteId])
  @@index([citaId])
  @@index([fechaProgramada])
}

model SolicitudCitaPublica {
  id               String   @id @default(uuid()) @db.VarChar(36)
  tenantId         String   @db.VarChar(36)
  fechaSolicitada  DateTime @db.DateTime(3)
  nombrePaciente   String   @db.VarChar(120)
  correoPaciente   String   @db.VarChar(150)
  telefonoPaciente String   @db.VarChar(25)
  motivo           String   @db.VarChar(500)
  createAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fechaSolicitada])
}

model TenantWhatsappConfig {
  id                     String   @id @default(uuid()) @db.VarChar(36)
  tenantId               String   @unique @db.VarChar(36)
  provider               String   @default("twilio") @db.VarChar(30)
  estado                 String   @default("desconectado") @db.VarChar(20)
  twilioAccountSid       String?  @db.VarChar(80)
  twilioAuthToken        String?  @db.VarChar(100)
  twilioWhatsappNumber   String?  @db.VarChar(30)
  webhookSecret          String?  @db.VarChar(100)
  verificationCode       String?  @db.VarChar(10)
  verifiedAt             DateTime?
  mensajeAutoRespuesta   String?  @db.VarChar(500)
  aceptaAgendamientoChat Boolean  @default(true) @db.Bit(1)
  activo                 Boolean  @default(true) @db.Bit(1)
  createAt               DateTime @default(now())
  updateAt               DateTime @updatedAt

  tenant   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mensajes TenantWhatsappMensaje[]

  @@index([estado])
}

model TenantWhatsappMensaje {
  id             String   @id @default(uuid()) @db.VarChar(36)
  tenantId       String   @db.VarChar(36)
  configId       String?  @db.VarChar(36)
  direccion      String   @db.VarChar(10)
  mensajeSid     String?  @unique @db.VarChar(80)
  fromPhone      String?  @db.VarChar(30)
  toPhone        String?  @db.VarChar(30)
  cuerpo         String?  @db.VarChar(1600)
  mediaCount     Int      @default(0)
  mediaUrls      String?  @db.Text
  estadoEntrega  String?  @db.VarChar(30)
  tipoEvento     String?  @db.VarChar(30)
  createAt       DateTime @default(now())

  tenant Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  config TenantWhatsappConfig? @relation(fields: [configId], references: [id], onDelete: SetNull)

  @@index([tenantId, createAt])
  @@index([configId])
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  SEGURO
  OTRO
}

enum PagoEstado {
  REGISTRADO
  APLICADO
  REVERTIDO
}

enum ReciboTipoConcepto {
  CONSULTA
  PLAN_TRATAMIENTO
  CUOTA_FINANCIAMIENTO
  ANTICIPO
  OTRO
}

enum FinanciamientoEstado {
  ACTIVO
  PAGADO
  VENCIDO
  CANCELADO
}

model Pago {
  id           String     @id @default(uuid()) @db.VarChar(36)
  tenantId     String?    @db.VarChar(36)
  ordenCobroId String     @unique @db.VarChar(36)
  monto        Decimal    @db.Decimal(10, 2)
  metodo       MetodoPago
  referencia   String?    @db.VarChar(100)
  fechaPago    DateTime   @default(now()) @db.DateTime(6)
  estado       PagoEstado @default(REGISTRADO)
  comentario   String?    @db.VarChar(255)

  tenant     Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ordenCobro OrdenDeCobro          @relation(fields: [ordenCobroId], references: [id], onDelete: Cascade)
  cuotas     CuotaFinanciamiento[]
  recibo     Recibo?

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ordenCobroId])
}

model Recibo {
  id                String             @id @default(uuid()) @db.VarChar(36)
  tenantId          String?            @db.VarChar(36)
  pagoId            String             @unique @db.VarChar(36)
  numero            String             @db.VarChar(30)
  fechaEmision      DateTime           @default(now()) @db.DateTime(6)
  tipoConcepto      ReciboTipoConcepto @default(OTRO)
  moneda            String             @default("HNL") @db.VarChar(10)
  subtotal          Decimal            @db.Decimal(10, 2)
  descuento         Decimal            @default(0) @db.Decimal(10, 2)
  impuesto          Decimal            @default(0) @db.Decimal(10, 2)
  total             Decimal            @db.Decimal(10, 2)
  saldoAnterior     Decimal?           @db.Decimal(10, 2)
  saldoPosterior    Decimal?           @db.Decimal(10, 2)
  notas             String?            @db.VarChar(255)
  emitidoPorUsuario String?            @db.VarChar(36)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant     Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pago       Pago            @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  emitidoPor Usuarios?       @relation("ReciboEmitidoPor", fields: [emitidoPorUsuario], references: [id])
  detalles   ReciboDetalle[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([pagoId])
  @@index([emitidoPorUsuario])
}

model ReciboDetalle {
  id             String  @id @default(uuid()) @db.VarChar(36)
  tenantId       String? @db.VarChar(36)
  reciboId       String  @db.VarChar(36)
  descripcion    String  @db.VarChar(255)
  cantidad       Decimal @default(1) @db.Decimal(10, 2)
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  referenciaTipo String? @db.VarChar(40)
  referenciaId   String? @db.VarChar(36)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recibo Recibo  @relation(fields: [reciboId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([reciboId])
  @@index([referenciaTipo, referenciaId])
}

model Financiamiento {
  id                String               @id @default(uuid()) @db.VarChar(36)
  tenantId          String?              @db.VarChar(36)
  pacienteId        String               @db.VarChar(36)
  cotizacionId      String?              @db.VarChar(36)
  planTratamientoId String?              @db.VarChar(36)
  montoTotal        Decimal              @db.Decimal(10, 2)
  anticipo          Decimal              @default(0) @db.Decimal(10, 2)
  saldo             Decimal              @db.Decimal(10, 2)
  cuotas            Int
  interes           Decimal              @default(0) @db.Decimal(5, 2)
  fechaInicio       DateTime             @db.DateTime(6)
  fechaFin          DateTime?            @db.DateTime(6)
  estado            FinanciamientoEstado @default(ACTIVO)
  createAt          DateTime             @default(now())
  updateAt          DateTime             @updatedAt

  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente             Paciente              @relation(fields: [pacienteId], references: [id])
  cotizacion           Cotizacion?           @relation(fields: [cotizacionId], references: [id])
  planTratamiento      PlanTratamiento?      @relation(fields: [planTratamientoId], references: [id])
  cuotasFinanciamiento CuotaFinanciamiento[]
  ordenesCobro         OrdenDeCobro[]
  consultas            Consulta[]

  @@index([tenantId])
  @@index([pacienteId])
  @@index([cotizacionId])
  @@index([planTratamientoId])
}

enum OrdenCobroEstado {
  PENDIENTE
  PAGADA
  ANULADA
}

model OrdenDeCobro {
  id                String           @id @default(uuid()) @db.VarChar(36)
  tenantId          String?          @db.VarChar(36)
  pacienteId        String           @db.VarChar(36)
  planTratamientoId String?          @db.VarChar(36)
  financiamientoId  String?          @db.VarChar(36)
  consultaId        String?          @db.VarChar(36)
  seguimientoId     String?          @db.VarChar(36)
  monto             Decimal          @db.Decimal(10, 2)
  concepto          String           @db.VarChar(255)
  estado            OrdenCobroEstado @default(PENDIENTE)
  fechaEmision      DateTime         @default(now()) @db.DateTime(6)
  fechaPago         DateTime?        @db.DateTime(6)

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente        Paciente         @relation(fields: [pacienteId], references: [id])
  planTratamiento PlanTratamiento? @relation(fields: [planTratamientoId], references: [id])
  financiamiento  Financiamiento?  @relation(fields: [financiamientoId], references: [id])
  consulta        Consulta?        @relation(fields: [consultaId], references: [id])
  seguimiento     Seguimiento?     @relation(fields: [seguimientoId], references: [id])
  pago            Pago?

  @@index([tenantId])
  @@index([pacienteId])
  @@index([planTratamientoId])
  @@index([financiamientoId])
  @@index([consultaId])
  @@index([seguimientoId])
}

model CuotaFinanciamiento {
  id               String    @id @default(uuid()) @db.VarChar(36)
  tenantId         String?   @db.VarChar(36)
  financiamientoId String    @db.VarChar(36)
  numero           Int
  monto            Decimal   @db.Decimal(10, 2)
  fechaVencimiento DateTime  @db.DateTime(6)
  pagada           Boolean   @default(false) @db.Bit(1)
  fechaPago        DateTime?
  pagoId           String?   @db.VarChar(36)

  tenant         Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financiamiento Financiamiento @relation(fields: [financiamientoId], references: [id], onDelete: Cascade)
  pago           Pago?          @relation(fields: [pagoId], references: [id], onDelete: SetNull)

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  @@unique([financiamientoId, numero])
  @@index([tenantId])
  @@index([financiamientoId])
  @@index([pagoId])
}

model ConstanciaMedica {
  id         String  @id @default(uuid()) @db.VarChar(36)
  tenantId   String? @db.VarChar(36)
  pacienteId String  @db.VarChar(36)
  medicoId   String  @db.VarChar(36)

  fechaGeneracion DateTime @default(now()) @db.DateTime(6)
  diasReposo      Int
  motivo          String   @db.Text

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paciente Paciente @relation(fields: [pacienteId], references: [id])
  medico   Medico   @relation(fields: [medicoId], references: [idEmpleado])

  @@index([tenantId])
  @@index([pacienteId])
  @@index([medicoId])
}
